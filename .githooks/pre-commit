#!/bin/sh
# Guard: rogue-racer.html is GENERATED from src/ by `bun build.ts`. If a commit
# touches src/ (or the build) but the committed rogue-racer.html doesn't match a
# fresh build, block the commit so a stale/hand-edited artifact never ships.
#
# Enable once per clone:  bun run hooks   (sets core.hooksPath to .githooks)

# Only run when src/, build.ts, or the artifact itself is staged.
if git diff --cached --name-only | grep -Eq '^(src/|build\.ts|rogue-racer\.html)'; then
  if ! command -v bun >/dev/null 2>&1; then
    echo "pre-commit: bun not found — skipping build check (install bun to enable it)."
    exit 0
  fi
  bun build.ts >/dev/null 2>&1 || { echo "pre-commit: build failed."; exit 1; }
  if ! git diff --quiet -- rogue-racer.html; then
    echo "pre-commit: rogue-racer.html is out of date with src/."
    echo "  Run:  bun run build && git add rogue-racer.html"
    exit 1
  fi
fi
exit 0
